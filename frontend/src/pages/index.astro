---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="home container" aria-label="操作を選択">
    <div class="action-grid">
      <a class="action-card action-card-create card" href="/create/">
        <h2>クイズを作る</h2>
        <span class="button button-primary">作成を始める</span>
      </a>

      <a class="action-card card" href="/play/">
        <h2>クイズに答える</h2>
        <span class="button button-outline">問題を始める</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  :global(body) {
    background-color: #d9dcdd;
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3CfeComponentTransfer%3E%3CfeFuncA type='table' tableValues='0 .1'/%3E%3C/feComponentTransfer%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.55'/%3E%3C/svg%3E"),
      radial-gradient(circle at center, rgb(67 72 75 / 16%) 0 2px, rgb(255 255 255 / 25%) 2.5px 3.5px, transparent 4px),
      linear-gradient(90deg, transparent calc(50% - 0.5px), rgb(91 97 100 / 12%) 50%, transparent calc(50% + 0.5px)),
      linear-gradient(180deg, transparent calc(50% - 0.5px), rgb(91 97 100 / 10%) 50%, transparent calc(50% + 0.5px)),
      linear-gradient(135deg, rgb(255 255 255 / 56%), rgb(179 184 186 / 18%) 52%, rgb(255 255 255 / 22%));
    background-position: 0 0, 0 16px, 0 0, 0 0, 0 0;
    background-size: 180px 180px, 180px 180px, 100% 100%, 100% 100%, 100% 100%;
  }

  :global(.site-header) {
    border-bottom-color: rgb(91 97 100 / 16%);
    background: rgb(225 228 229 / 82%);
  }

  .home {
    display: grid;
    width: min(calc(100% - 48px), 940px);
    min-height: calc(100svh - 64px);
    padding-block: 48px;
    place-items: center;
  }

  .action-grid {
    display: grid;
    width: 100%;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .action-card {
    display: flex;
    min-height: 360px;
    align-items: center;
    justify-content: center;
    gap: 40px;
    padding: 40px;
    border-radius: 24px;
    background: rgb(248 249 249 / 92%);
    flex-direction: column;
    text-align: center;
    backdrop-filter: blur(8px);
    transition: background-color 160ms ease, border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
  }

  .action-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-hairline-strong);
    box-shadow: var(--shadow-card);
  }

  .action-card-create {
    border-color: var(--color-ink);
    background: var(--color-ink);
  }

  .action-card-create:hover {
    border-color: #1c1917;
    background: #1c1917;
  }

  .action-card h2 {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 500;
    letter-spacing: -0.4px;
  }

  .action-card-create h2 {
    color: white;
  }

  .action-card .button {
    width: min(100%, 180px);
  }

  .action-card-create .button {
    background: white;
    color: var(--color-ink);
  }

  .action-card-create .button:hover {
    background: var(--color-surface);
  }

  @media (max-width: 767px) {
    .home {
      width: min(calc(100% - 32px), 940px);
      min-height: calc(100svh - 60px);
      padding-block: 32px;
    }

    .action-grid {
      gap: 16px;
    }

    .action-card {
      min-height: 320px;
      gap: 32px;
      padding: 24px;
    }
  }

  @media (max-width: 479px) {
    .action-grid {
      grid-template-columns: 1fr;
    }

    .action-card {
      min-height: 220px;
    }
  }
</style>
