---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="home container" aria-label="操作を選択">
    <div class="action-grid">
      <a class="action-card action-card-create card" href="/create/">
        <div>
          <span class="action-label">ログインが必要</span>
          <h2>クイズを作る</h2>
          <p>画像を選び、見せる範囲、問題文、4つの選択肢を設定します。</p>
        </div>
        <span class="button button-primary">
          作成を始める <span aria-hidden="true">→</span>
        </span>
      </a>

      <a class="action-card card" href="/play/">
        <div>
          <span class="action-label">ログイン不要</span>
          <h2>クイズに答える</h2>
          <p>公開されている問題からランダムに出題します。</p>
        </div>
        <span class="button button-outline">
          問題を始める <span aria-hidden="true">→</span>
        </span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .home {
    padding-block: 64px 96px;
  }

  .action-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .action-card {
    display: flex;
    min-height: 330px;
    padding: 32px;
    justify-content: space-between;
    flex-direction: column;
    box-shadow: none;
    transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
  }

  .action-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-hairline-strong);
    box-shadow: var(--shadow-card);
  }

  .action-card-create {
    border-color: var(--color-hairline-strong);
  }

  .action-label {
    display: inline-block;
    margin-bottom: 28px;
    padding: 5px 10px;
    border-radius: 9999px;
    background: var(--color-surface);
    color: var(--color-muted);
    font-size: 12px;
    font-weight: 600;
  }

  .action-card h2 {
    margin-bottom: 12px;
    font-family: var(--font-body);
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 500;
    letter-spacing: -0.4px;
  }

  .action-card p {
    max-width: 420px;
    margin: 0;
    color: var(--color-muted);
    font-size: 15px;
  }

  .action-card .button {
    width: fit-content;
    margin-top: 32px;
  }

  @media (max-width: 767px) {
    .home {
      padding-block: 40px 64px;
    }

    .action-grid {
      gap: 14px;
    }

    .action-card {
      min-height: 290px;
      padding: 24px;
    }
  }

  @media (max-width: 479px) {
    .home {
      padding-block: 32px 56px;
    }

    .action-grid {
      grid-template-columns: 1fr;
    }

    .action-card {
      min-height: 260px;
    }
  }
</style>
